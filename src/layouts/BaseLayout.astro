---
// Shared <head> + cosmic (black/gold) design tokens for the blog pages.
// The homepage does NOT use this layout — it keeps its own verbatim <head>/<style>
// (ported byte-for-byte from the original index.html) so its visual output is
// unchanged. This layout exists so blog pages share the same tokens and chrome.
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  schemaJsonLd?: string;
}
const {
  title,
  description = 'Cortex is an agentic operating system — a desktop environment where AI agents plan, remember, and act, presided over by a living orb. In active development.',
  ogImage = '/og.png',
  ogType = 'website',
  schemaJsonLd,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#07070a" />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Cortex" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
{schemaJsonLd && <script type="application/ld+json" set:html={schemaJsonLd} />}
<style is:global>
  :root {
    --bg: #07070a;
    --surface: #101016;
    --ink: #e8e6df;
    --muted: #8a8778;
    --gold: #d4a843;
    --gold-soft: rgba(212, 168, 67, 0.35);
    --gold-faint: rgba(212, 168, 67, 0.14);
    --line: #23222b;
    --sans: "Segoe UI", system-ui, -apple-system, "Helvetica Neue", sans-serif;
    --mono: Consolas, "Cascadia Mono", "SF Mono", Menlo, monospace;
    --serif: Georgia, "Times New Roman", serif;
    --radius: 10px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-padding-top: 2rem; }
  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  ::selection { background: var(--gold); color: var(--bg); }

  a { color: var(--gold); text-decoration: none; }
  a:hover { text-decoration: underline; text-underline-offset: 3px; }
  :focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; border-radius: 2px; }

  .skip {
    position: absolute; left: -9999px; top: 0; z-index: 50;
    background: var(--gold); color: var(--bg);
    padding: 0.6rem 1rem; font-size: 0.85rem; border-radius: 0 0 6px 0;
  }
  .skip:focus { left: 0; }

  .wrap { width: min(760px, calc(100% - 2.75rem)); margin-inline: auto; }

  /* ---------- header ---------- */
  .top {
    display: flex; align-items: center; justify-content: space-between;
    width: min(1060px, calc(100% - 2.75rem)); margin-inline: auto;
    padding-top: 1.4rem; padding-bottom: 1.4rem;
  }
  .wordmark {
    font-size: 0.85rem; letter-spacing: 0.34em; font-weight: 600;
    color: var(--ink); display: flex; align-items: center; gap: 0.6rem;
  }
  .wordmark:hover { text-decoration: none; color: var(--gold); }
  .wordmark::before {
    content: ""; width: 9px; height: 9px; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #f0cf7e, var(--gold) 60%);
    box-shadow: 0 0 8px var(--gold-soft);
  }
  .top-nav { display: flex; align-items: center; gap: 1.4rem; }
  .top-link {
    font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.08em;
    color: var(--muted);
  }
  .top-link:hover { color: var(--gold); text-decoration: none; }
  .top-link[aria-current="page"] { color: var(--gold); }

  /* ---------- main ---------- */
  main { flex: 1 0 auto; padding-block: clamp(2.5rem, 6vw, 4.5rem); }

  /* shared type helpers */
  .kicker {
    font-size: 0.78rem; letter-spacing: 0.24em; text-indent: 0.24em;
    text-transform: uppercase; color: var(--gold); font-weight: 600;
  }
  @supports (-webkit-background-clip: text) or (background-clip: text) {
    .kicker {
      background: linear-gradient(100deg, #f0cf7e 0%, var(--gold) 48%, #96762a 100%);
      -webkit-background-clip: text; background-clip: text;
      color: transparent;
    }
  }
  .lede { color: var(--muted); margin-top: 1.05rem; font-size: 1.04rem; }

  /* ---------- footer ---------- */
  footer {
    flex-shrink: 0;
    border-top: 1px solid var(--line);
    padding: 2.6rem 0 3rem; text-align: center;
    color: var(--muted); font-size: 0.82rem; letter-spacing: 0.06em;
  }
  footer .fmark {
    display: block; width: 10px; height: 10px; border-radius: 50%;
    margin: 0 auto 1.1rem;
    background: radial-gradient(circle at 35% 30%, #f0cf7e, var(--gold) 60%);
    box-shadow: 0 0 10px var(--gold-soft);
  }
</style>
</head>
<body>
<a class="skip" href="#main">Skip to content</a>

<header class="top">
  <a class="wordmark" href="/" aria-label="Cortex — home">CORTEX</a>
  <nav class="top-nav">
    <a class="top-link" href="/blog" aria-current={Astro.url.pathname.startsWith('/blog') ? 'page' : undefined}>blog</a>
    <a class="top-link" href="https://github.com/GitJoe345" target="_blank" rel="noopener">github ↗</a>
  </nav>
</header>

<main id="main" class="wrap">
  <slot />
</main>

<footer>
  <span class="fmark" aria-hidden="true"></span>
  cortex-os.dev · built by <a href="https://github.com/GitJoe345" target="_blank" rel="noopener">GitJoe345</a>
</footer>
</body>
</html>
