---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Field Notes — Cortex"
  description="Field notes on building an agentic operating system: AI agents, persistent memory, orchestration, and the modules that make up Cortex."
>
  <div class="blog-head">
    <p class="kicker">The log</p>
    <h1>Field notes</h1>
    <p class="lede">
      Thinking out loud on agentic operating systems — memory, orchestration, voice,
      and the parts of Cortex as they land on the spine.
    </p>
  </div>

  {posts.length === 0 ? (
    <p class="empty">No field notes yet — the log begins soon.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-card">
          <a href={`/blog/${post.id}/`}>
            <time datetime={post.data.publishDate.toISOString()}>
              {fmtDate(post.data.publishDate)}
            </time>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <span class="tags">{post.data.tags.join(' · ')}</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style is:global>
  .blog-head { margin-bottom: clamp(2.4rem, 6vw, 3.6rem); }
  .blog-head h1 {
    font-size: clamp(2.1rem, 6vw, 3rem);
    font-weight: 200; letter-spacing: 0.06em; line-height: 1.15;
    margin-top: 0.7rem;
  }
  .empty {
    color: var(--muted); font-family: var(--mono); font-size: 0.9rem;
    padding: 2rem 0;
  }
  .post-list { list-style: none; display: flex; flex-direction: column; gap: 1px;
    background: var(--line); border: 1px solid var(--line); border-radius: var(--radius);
    overflow: hidden; }
  .post-card { background: var(--surface); }
  .post-card > a {
    display: block; padding: 1.6rem 1.7rem 1.75rem; color: inherit;
    transition: background 0.25s ease;
  }
  .post-card > a:hover { text-decoration: none; background: #14141b; }
  .post-card time {
    font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold);
  }
  .post-card h2 {
    font-size: clamp(1.25rem, 3vw, 1.55rem); font-weight: 300;
    letter-spacing: 0.02em; line-height: 1.3; margin: 0.55rem 0 0.6rem;
    color: var(--ink);
  }
  .post-card p { color: var(--muted); font-size: 0.96rem; }
  .post-card .tags {
    display: inline-block; margin-top: 0.9rem;
    font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.1em;
    color: var(--muted);
  }
</style>
